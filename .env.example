# Backend Environment Variables
PORT=4000
DATABASE_URL="file:./dev.db"
JWT_SECRET="generate_a_secure_random_string_here"

# Automation
# Set to "true" to use built-in cron scheduling instead of an external workflow tool (n8n/Make)
USE_INTERNAL_AUTOMATION=false
# API key for /api/automation/* endpoints (used by n8n / Make)
AUTOMATION_API_KEY=""

# External Integrations (Optional)
VAPI_API_KEY=""
GEMINI_API_KEY=""
SENTRY_BACKEND_DSN=""

# Frontend Environment Variables
VITE_API_BASE_URL="http://localhost:4000/api"
