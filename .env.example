# ============================================================
# Backend Environment Variables
# ============================================================

PORT=4000

# PostgreSQL connection string
# Generate with: psql or use Supabase / Neon / Render
DATABASE_URL="postgresql://user:password@localhost:5432/clinic_db"

# Required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate_a_secure_random_string_here"

# Required — used to encrypt sensitive backend values.
DB_ENCRYPTION_KEY="generate_a_secure_random_string_here"

NODE_ENV=development

# Your deployed frontend URL — used to lock down CORS in production
FRONTEND_URL="https://your-frontend.vercel.app"

# ============================================================
# Email (Required for password reset)
# Use any SMTP provider: Resend, Sendgrid, Mailgun, etc.
# Resend example: host=smtp.resend.com, port=465, user=resend, pass=<API_KEY>
# ============================================================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ClinicFlow <no-reply@yourdomain.com>"

# ============================================================
# Redis (Required for production background jobs)
# Use Upstash Redis for serverless-compatible Redis
# ============================================================
REDIS_URL=""
DISABLE_REDIS=true

# ============================================================
# Automation
# ============================================================
USE_INTERNAL_AUTOMATION=false
AUTOMATION_API_KEY=""

# Webhook HMAC signing secret — generate same way as JWT_SECRET
WEBHOOK_SECRET=""

# ============================================================
# Managed SaaS Integrations (Required in production)
# ============================================================
GEMINI_API_KEY=""

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=""

# ============================================================
# Sentry — leave empty to disable error tracking
# ============================================================
SENTRY_BACKEND_DSN=""

# ============================================================
# Frontend Environment Variables (Vite)
# ============================================================
VITE_API_BASE_URL="http://localhost:4000/api"
VITE_GOOGLE_CLIENT_ID=""
VITE_SENTRY_DSN=""

# ============================================================
# Optional automation endpoint
# ============================================================
BACKEND_API_URL="https://your-backend.example.com/api"

# n8n webhook base URL (required for SMS sending)
N8N_WEBHOOK_URL="https://your-instance.app.n8n.cloud/webhook"

# Global Vonage fallback credentials (per-clinic creds stored in DB)
VONAGE_API_KEY=""
VONAGE_API_SECRET=""
VONAGE_FROM_NAME="ClinicFlow"
