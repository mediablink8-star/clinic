# Backend Environment Variables
PORT=4000

# PostgreSQL connection string (use SQLite file path for local dev only)
DATABASE_URL="postgresql://user:password@localhost:5432/clinic_db"

# Optional separate direct connection string for running production migrations manually
# SUPABASE_DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="generate_a_secure_random_string_here"

# Required — used to encrypt API keys stored in DB. Generate same way as JWT_SECRET.
DB_ENCRYPTION_KEY="generate_a_secure_random_string_here"

NODE_ENV=development

# Your deployed frontend URL — used to lock down CORS in production
FRONTEND_URL="https://your-frontend.vercel.app"

# Automation
USE_INTERNAL_AUTOMATION=false
AUTOMATION_API_KEY=""

# Webhook HMAC signing secret
WEBHOOK_SECRET=""

# External Integrations (Optional)
VAPI_API_KEY=""
GEMINI_API_KEY=""
TWILIO_AUTH_TOKEN=""
REDIS_URL=""

# Sentry — leave empty to disable
SENTRY_BACKEND_DSN=""

# Frontend Environment Variables
VITE_API_BASE_URL="http://localhost:4000/api"
VITE_GOOGLE_CLIENT_ID=""

# n8n Environment Variables
BACKEND_API_URL="https://your-backend.example.com/api"
TWILIO_PHONE_NUMBER="+10000000000"
