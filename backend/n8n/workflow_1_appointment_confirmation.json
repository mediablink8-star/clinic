{
  "name": "Workflow 1 — Appointment Confirmation SMS (Twilio)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "appointment-created",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "node_webhook_appt",
      "name": "Receive Appointment Event",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 400]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "exec-id",
              "name": "executionId",
              "value": "={{ $json.data?.appointmentId || $json.body?.data?.appointmentId || $execution.id }}",
              "type": "string"
            },
            {
              "id": "entity-id",
              "name": "entityId",
              "value": "={{ $json.data?.appointmentId || $json.body?.data?.appointmentId || '' }}",
              "type": "string"
            },
            {
              "id": "entity-type",
              "name": "entityType",
              "value": "appointment",
              "type": "string"
            },
            {
              "id": "phone",
              "name": "phone",
              "value": "={{ $json.data?.phone || $json.body?.data?.phone }}",
              "type": "string"
            },
            {
              "id": "smsBody",
              "name": "smsBody",
              "value": "=Ραντεβού επιβεβαιώθηκε: {{ $json.data?.patientName || $json.body?.data?.patientName }}, {{ $json.data?.date || $json.body?.data?.date }} {{ $json.data?.time || $json.body?.data?.time }} — {{ $json.clinic?.name || $json.body?.clinic?.name || 'Ιατρείο' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node_format_msg",
      "name": "Format Confirmation Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{ $env.TWILIO_ACCOUNT_SID }}/Messages.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Basic {{ $buffer($env.TWILIO_ACCOUNT_SID + ':' + $env.TWILIO_AUTH_TOKEN).toString('base64') }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "form",
        "bodyParameters": {
          "formBodyParameters": {
            "parameters": [
              {
                "name": "From",
                "value": "={{ $env.TWILIO_ALPHA_SENDER_ID || $env.TWILIO_PHONE_NUMBER }}"
              },
              {
                "name": "To",
                "value": "={{ $json.phone }}"
              },
              {
                "name": "Body",
                "value": "={{ $json.smsBody }}"
              }
            ]
          }
        },
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_twilio_appt",
      "name": "Send Confirmation SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 400],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 10000,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "check-sid",
              "leftValue": "={{ $json.sid }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node_check_appt",
      "name": "SMS Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "log",
              "name": "log",
              "value": "=SMS sent to {{ $('Format Confirmation Message').first().json.phone }} | messageId: {{ $json.sid }}",
              "type": "string"
            },
            {
              "id": "status",
              "name": "smsStatus",
              "value": "sent",
              "type": "string"
            },
            {
              "id": "msg-id",
              "name": "messageId",
              "value": "={{ $json.sid }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node_log_success",
      "name": "Log SMS Sent",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "error",
              "name": "error",
              "value": "={{ $json.message || $json.errorMessage || 'Unknown SMS failure' }}",
              "type": "string"
            },
            {
              "id": "code",
              "name": "errorCode",
              "value": "={{ $json.status || $json.code || 'error' }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node_log_failure",
      "name": "Log SMS Failure",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1120, 500]
    }
  ],
  "connections": {
    "Receive Appointment Event": {
      "main": [
        [
          {
            "node": "Format Confirmation Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Confirmation Message": {
      "main": [
        [
          {
            "node": "Send Confirmation SMS",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Confirmation SMS": {
      "main": [
        [
          {
            "node": "SMS Sent?",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log SMS Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "SMS Sent?": {
      "main": [
        [
          {
            "node": "Log SMS Sent",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log SMS Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": "workflow_0_global_error_handler"
  }
}
