{
  "name": "Workflow 2 — Direct SMS Delivery",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "send-sms",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node_webhook_sms",
      "name": "Receive SMS Request",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.body.phone }}", "operation": "isNotEmpty" },
            { "value1": "={{ $json.body.message }}", "operation": "isNotEmpty" }
          ],
          "number": [
            {
              "value1": "={{ $json.body.message ? $json.body.message.length : 0 }}",
              "operation": "smallerEqual",
              "value2": 500
            }
          ]
        }
      },
      "id": "node_validate_sms",
      "name": "Validate Payload",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"invalid payload or message too long\" }",
        "options": { "responseCode": 400 }
      },
      "id": "node_error_validation",
      "name": "Return 400",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 460]
    },
    {
      "parameters": {
        "operation": "send",
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $json.body.phone }}",
        "message": "={{ $json.body.message }}",
        "options": {}
      },
      "id": "node_twilio_sms",
      "name": "Send SMS via Twilio",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [680, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 10000,
      "credentials": {
        "twilioApi": {
          "id": "twilio_creds",
          "name": "Twilio Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.sid }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_check_sent",
      "name": "SMS Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": true, \"status\": \"delivered\" }",
        "options": { "responseCode": 200 }
      },
      "id": "node_success",
      "name": "Return Delivered",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1120, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"status\": \"failed\" }",
        "options": { "responseCode": 502 }
      },
      "id": "node_failed",
      "name": "Return Failed",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1120, 400]
    }
  ],
  "connections": {
    "Receive SMS Request": {
      "main": [[{ "node": "Validate Payload", "type": "main", "index": 0 }]]
    },
    "Validate Payload": {
      "main": [
        [{ "node": "Send SMS via Twilio", "type": "main", "index": 0 }],
        [{ "node": "Return 400", "type": "main", "index": 0 }]
      ]
    },
    "Send SMS via Twilio": {
      "main": [[{ "node": "SMS Sent?", "type": "main", "index": 0 }]]
    },
    "SMS Sent?": {
      "main": [
        [{ "node": "Return Delivered", "type": "main", "index": 0 }],
        [{ "node": "Return Failed", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
