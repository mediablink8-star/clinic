{
  "name": "Workflow 2 — Direct SMS",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "direct-sms",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "node_webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "direct-sms"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "twilio-sid",
              "name": "TWILIO_ACCOUNT_SID",
              "value": "YOUR_TWILIO_ACCOUNT_SID",
              "type": "string"
            },
            {
              "id": "twilio-token",
              "name": "TWILIO_AUTH_TOKEN",
              "value": "YOUR_TWILIO_AUTH_TOKEN",
              "type": "string"
            },
            {
              "id": "twilio-sender",
              "name": "TWILIO_SENDER",
              "value": "YOUR_TWILIO_SENDER",
              "type": "string"
            },
            {
              "id": "backend-url",
              "name": "BACKEND_API_URL",
              "value": "YOUR_BACKEND_API_URL",
              "type": "string"
            },
            {
              "id": "api-key",
              "name": "AUTOMATION_API_KEY",
              "value": "YOUR_AUTOMATION_API_KEY",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node_set_creds",
      "name": "Set Credentials",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{ $('Set Credentials').first().json.TWILIO_ACCOUNT_SID }}/Messages.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Basic {{ $base64($('Set Credentials').first().json.TWILIO_ACCOUNT_SID + ':' + $('Set Credentials').first().json.TWILIO_AUTH_TOKEN) }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "form",
        "formBodyParameters": {
          "parameters": [
            {
              "name": "From",
              "value": "={{ $('Set Credentials').first().json.TWILIO_SENDER }}"
            },
            {
              "name": "To",
              "value": "={{ $json.patientPhone }}"
            },
            {
              "name": "Body",
              "value": "={{ $json.message }}"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_send_sms",
      "name": "Send Direct SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Credentials').first().json.BACKEND_API_URL }}/automation/log-sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $('Set Credentials').first().json.AUTOMATION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"appointmentId\": \"{{ $json.appointmentId }}\",\n  \"patientPhone\": \"{{ $json.patientPhone }}\",\n  \"sid\": \"{{ $json.sid }}\",\n  \"status\": \"{{ $json.status }}\",\n  \"type\": \"direct\"\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_log_sms",
      "name": "Log SMS to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Credentials').first().json.BACKEND_API_URL }}/automation/log-error",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $('Set Credentials').first().json.AUTOMATION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"sms_failed\",\n  \"patientPhone\": \"{{ $('Send Direct SMS').first().json.patientPhone }}\",\n  \"error\": \"{{ $('Send Direct SMS').last().json.error || $json.message }}\"\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_log_error",
      "name": "Log SMS Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 500]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Set Credentials",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Credentials": {
      "main": [
        [
          {
            "node": "Send Direct SMS",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Direct SMS": {
      "main": [
        [
          {
            "node": "Log SMS to Backend",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log SMS Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
