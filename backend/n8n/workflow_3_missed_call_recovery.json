{
  "name": "Workflow 3 — Missed Call Recovery",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "missed-call",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node_webhook_trigger",
      "name": "Missed Call Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.headers['x-webhook-key'] }}",
              "operation": "equal",
              "value2": "REPLACE_WITH_YOUR_WEBHOOK_SECRET"
            }
          ]
        }
      },
      "id": "node_auth_check",
      "name": "Auth Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"Unauthorized\" }",
        "options": {"responseCode": 401}
      },
      "id": "node_unauthorized",
      "name": "Return 401",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 480]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {"value1": "={{ $json.body.phone }}", "operation": "isNotEmpty"},
            {"value1": "={{ $json.body.clinicId }}", "operation": "isNotEmpty"},
            {"value1": "={{ $json.body.missedCallId }}", "operation": "isNotEmpty"}
          ]
        }
      },
      "id": "node_validate",
      "name": "Validate Payload",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"missing required fields\" }",
        "options": {"responseCode": 400}
      },
      "id": "node_bad_request",
      "name": "Return 400",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 480]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"received\": true }",
        "options": {"responseCode": 200}
      },
      "id": "node_respond_ok",
      "name": "Respond 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {"name": "phone", "value": "={{ $json.body.phone }}"},
            {"name": "clinicId", "value": "={{ $json.body.clinicId }}"},
            {"name": "missedCallId", "value": "={{ $json.body.missedCallId }}"},
            {"name": "name", "value": "={{ $json.body.name || '' }}"},
            {"name": "vonageApiKey", "value": "={{ $json.body.vonageApiKey || 'REPLACE_WITH_YOUR_VONAGE_API_KEY' }}"},
            {"name": "vonageApiSecret", "value": "={{ $json.body.vonageApiSecret || 'REPLACE_WITH_YOUR_VONAGE_API_SECRET' }}"},
            {"name": "vonageFromName", "value": "={{ $json.body.vonageFromName || 'REPLACE_WITH_YOUR_VONAGE_FROM_NAME' }}"},
            {"name": "backendUrl", "value": "={{ $json.body.backendUrl || 'https://backend-l9el.onrender.com/api' }}"}
          ]
        }
      },
      "id": "node_set_vars",
      "name": "Set Variables",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {"name": "smsBody", "value": "={{ $json.body.smsBody || \"Γεια! Χάσαμε την κλήση σας. Κλείστε ραντεβού εδώ: [link]\" }}"}
          ]
        }
      },
      "id": "node_sms_body",
      "name": "Set SMS Body",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "url": "https://rest.nexmo.com/sms/json",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "api_key", "value": "={{ $node[\"Set Variables\"].json.vonageApiKey }}"},
            {"name": "api_secret", "value": "={{ $node[\"Set Variables\"].json.vonageApiSecret }}"},
            {"name": "from", "value": "={{ $node[\"Set Variables\"].json.vonageFromName }}"},
            {"name": "to", "value": "={{ $node[\"Set Variables\"].json.phone }}"},
            {"name": "text", "value": "={{ $json.smsBody }}"},
            {"name": "type", "value": "unicode"}
          ]
        },
        "options": {"timeout": 10000}
      },
      "id": "node_send_sms",
      "name": "Send Recovery SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1560, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {"value1": "={{ $json.messages[0]['status'] }}", "operation": "equal", "value2": "0"}
          ]
        }
      },
      "id": "node_sms_ok",
      "name": "SMS Sent OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {"name": "result", "value": "sent"},
            {"name": "messageId", "value": "={{ $json.messages[0]['message-id'] }}"}
          ]
        }
      },
      "id": "node_log_success",
      "name": "Log Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2000, 200]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {"name": "result", "value": "failed"},
            {"name": "error", "value": "={{ $json.errorMessage || 'SMS send failed' }}"}
          ]
        }
      },
      "id": "node_log_failure",
      "name": "Log Failure",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2000, 400]
    },
    {
      "parameters": {
        "url": "={{ $node[\"Set Variables\"].json.backendUrl }}/automation/mark-recovered",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "clinicId", "value": "={{ $node[\"Set Variables\"].json.clinicId }}"},
            {"name": "missedCallId", "value": "={{ $node[\"Set Variables\"].json.missedCallId }}"},
            {"name": "smsStatus", "value": "sent"},
            {"name": "messageId", "value": "={{ $node[\"Log Success\"].json.messageId }}"}
          ]
        },
        "options": {"timeout": 10000}
      },
      "id": "node_mark_recovered",
      "name": "Mark SMS Sent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2220, 200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "url": "={{ $node[\"Set Variables\"].json.backendUrl }}/automation/send-notification",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "type", "value": "sms_failed"},
            {"name": "executionId", "value": "={{ $node[\"Set Variables\"].json.missedCallId }}"},
            {"name": "entityType", "value": "missed_call"},
            {"name": "entityId", "value": "={{ $node[\"Set Variables\"].json.missedCallId }}"},
            {"name": "phone", "value": "={{ $node[\"Set Variables\"].json.phone }}"},
            {"name": "error", "value": "={{ $node[\"Log Failure\"].json.error }}"}
          ]
        },
        "options": {"timeout": 10000}
      },
      "id": "node_notify_backend_failure",
      "name": "Notify Backend of Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2220, 400],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Missed Call Webhook": {"main": [[{"node": "Auth Check", "type": "main", "index": 0}]]},
    "Auth Check": {"main": [[{"node": "Validate Payload", "type": "main", "index": 0}], [{"node": "Return 401", "type": "main", "index": 0}]]},
    "Validate Payload": {"main": [[{"node": "Respond 200", "type": "main", "index": 0}], [{"node": "Return 400", "type": "main", "index": 0}]]},
    "Respond 200": {"main": [[{"node": "Set Variables", "type": "main", "index": 0}]]},
    "Set Variables": {"main": [[{"node": "Set SMS Body", "type": "main", "index": 0}]]},
    "Set SMS Body": {"main": [[{"node": "Send Recovery SMS", "type": "main", "index": 0}]]},
    "Send Recovery SMS": {"main": [[{"node": "SMS Sent OK?", "type": "main", "index": 0}]]},
    "SMS Sent OK?": {"main": [[{"node": "Log Success", "type": "main", "index": 0}], [{"node": "Log Failure", "type": "main", "index": 0}]]},
    "Log Success": {"main": [[{"node": "Mark SMS Sent", "type": "main", "index": 0}]]},
    "Log Failure": {"main": [[{"node": "Notify Backend of Failure", "type": "main", "index": 0}]]}
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": "workflow_0_global_error_handler"
  }
}
