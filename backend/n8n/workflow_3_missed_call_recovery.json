{
  "name": "Workflow 3 — Missed Call Recovery",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "missed-call-event",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node_webhook_trigger",
      "name": "Missed Call Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.body.data.phone }}", "operation": "isNotEmpty" },
            { "value1": "={{ $json.body.data.clinicId }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_validate",
      "name": "Validate Payload",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"missing phone or clinicId\" }",
        "options": { "responseCode": 400 }
      },
      "id": "node_bad_request",
      "name": "Return 400",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 500]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/missed-call",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "phone", "value": "={{ $json.body.data.phone }}" },
            { "name": "clinicId", "value": "={{ $json.body.data.clinicId }}" },
            { "name": "callSid", "value": "={{ $json.body.data.callSid || '' }}" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "id": "node_record_missed_call",
      "name": "Record Missed Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [680, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            { "value1": "={{ $json.data?.duplicate }}", "value2": true }
          ]
        }
      },
      "id": "node_is_duplicate",
      "name": "Is Duplicate?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": true, \"note\": \"duplicate ignored\" }",
        "options": { "responseCode": 200 }
      },
      "id": "node_stop_duplicate",
      "name": "Stop — Duplicate",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1120, 460]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.data?.smsStatus }}", "operation": "equal", "value2": "scheduled" }
          ]
        }
      },
      "id": "node_is_scheduled",
      "name": "Is Scheduled (OOH)?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": true, \"note\": \"sms scheduled for working hours\" }",
        "options": { "responseCode": 200 }
      },
      "id": "node_stop_scheduled",
      "name": "Stop — Scheduled",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1340, 460]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "missedCallId", "value": "={{ $json.data.missedCallId }}" },
            { "name": "phone", "value": "={{ $node[\"Missed Call Webhook\"].json.body.data.phone }}" },
            { "name": "clinicId", "value": "={{ $node[\"Missed Call Webhook\"].json.body.data.clinicId }}" },
            { "name": "clinicName", "value": "={{ $node[\"Missed Call Webhook\"].json.body.clinic?.name || 'Ιατρείο' }}" },
            { "name": "clinicServices", "value": "={{ JSON.stringify($node[\"Missed Call Webhook\"].json.body.clinic?.services || []) }}" },
            { "name": "clinicPolicies", "value": "={{ $node[\"Missed Call Webhook\"].json.body.clinic?.policies?.cancellation || '' }}" },
            { "name": "workingHours", "value": "={{ JSON.stringify($node[\"Missed Call Webhook\"].json.body.clinic?.workingHours || {}) }}" }
          ]
        }
      },
      "id": "node_extract_context",
      "name": "Extract Clinic Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "=You are a friendly medical clinic assistant. Write a short SMS in Greek (max 160 chars) to a patient whose call was missed. Clinic: {{ $json.clinicName }}. Services: {{ $json.clinicServices }}. Be warm, professional, encourage booking. No emojis."
            },
            {
              "role": "user",
              "content": "Write the recovery SMS now."
            }
          ]
        },
        "options": {}
      },
      "id": "node_ai_message",
      "name": "Generate AI Recovery SMS",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [1560, 300],
      "continueOnFail": true,
      "credentials": {
        "openAiApi": {
          "id": "openai_creds",
          "name": "OpenAI Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.message?.content }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_ai_ok",
      "name": "AI Message OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "smsBody", "value": "={{ $json.message.content }}" }
          ]
        }
      },
      "id": "node_use_ai",
      "name": "Use AI Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2000, 200]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "smsBody", "value": "=Γεια σας, χάσαμε την κλήση σας. Θέλετε να κλείσουμε ραντεβού; Απαντήστε ή καλέστε μας." }
          ]
        }
      },
      "id": "node_fallback",
      "name": "Use Fallback Message",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2000, 400]
    },
    {
      "parameters": {
        "operation": "send",
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $node[\"Extract Clinic Context\"].json.phone }}",
        "message": "={{ $json.smsBody }}",
        "options": {}
      },
      "id": "node_send_sms",
      "name": "Send Recovery SMS",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [2220, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 10000,
      "credentials": {
        "twilioApi": {
          "id": "twilio_creds",
          "name": "Twilio Account"
        }
      }
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/pending-notifications",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": { "timeout": 10000 }
      },
      "id": "node_poll_notifications",
      "name": "Poll Pending Notifications",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2440, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    },
    {
      "parameters": {
        "fieldToSplitOut": "data",
        "options": {}
      },
      "id": "node_split_notifications",
      "name": "Split Notifications",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [2660, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/send-notification",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "notificationId", "value": "={{ $json.id }}" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "id": "node_send_notification",
      "name": "Send Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2880, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": true, \"status\": \"recovery_initiated\" }",
        "options": { "responseCode": 200 }
      },
      "id": "node_success",
      "name": "Return Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [3100, 300]
    }
  ],
  "connections": {
    "Missed Call Webhook": {
      "main": [[{ "node": "Validate Payload", "type": "main", "index": 0 }]]
    },
    "Validate Payload": {
      "main": [
        [{ "node": "Record Missed Call", "type": "main", "index": 0 }],
        [{ "node": "Return 400", "type": "main", "index": 0 }]
      ]
    },
    "Record Missed Call": {
      "main": [[{ "node": "Is Duplicate?", "type": "main", "index": 0 }]]
    },
    "Is Duplicate?": {
      "main": [
        [{ "node": "Stop — Duplicate", "type": "main", "index": 0 }],
        [{ "node": "Is Scheduled (OOH)?", "type": "main", "index": 0 }]
      ]
    },
    "Is Scheduled (OOH)?": {
      "main": [
        [{ "node": "Stop — Scheduled", "type": "main", "index": 0 }],
        [{ "node": "Extract Clinic Context", "type": "main", "index": 0 }]
      ]
    },
    "Extract Clinic Context": {
      "main": [[{ "node": "Generate AI Recovery SMS", "type": "main", "index": 0 }]]
    },
    "Generate AI Recovery SMS": {
      "main": [[{ "node": "AI Message OK?", "type": "main", "index": 0 }]]
    },
    "AI Message OK?": {
      "main": [
        [{ "node": "Use AI Message", "type": "main", "index": 0 }],
        [{ "node": "Use Fallback Message", "type": "main", "index": 0 }]
      ]
    },
    "Use AI Message": {
      "main": [[{ "node": "Send Recovery SMS", "type": "main", "index": 0 }]]
    },
    "Use Fallback Message": {
      "main": [[{ "node": "Send Recovery SMS", "type": "main", "index": 0 }]]
    },
    "Send Recovery SMS": {
      "main": [[{ "node": "Poll Pending Notifications", "type": "main", "index": 0 }]]
    },
    "Poll Pending Notifications": {
      "main": [[{ "node": "Split Notifications", "type": "main", "index": 0 }]]
    },
    "Split Notifications": {
      "main": [[{ "node": "Send Notification", "type": "main", "index": 0 }]]
    },
    "Send Notification": {
      "main": [[{ "node": "Return Success", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
