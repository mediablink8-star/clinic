{
  "name": "Workflow 5 — Inbound SMS Reply & Mark Recovered",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inbound-sms",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node_webhook_inbound",
      "name": "Receive Inbound SMS",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.headers['x-webhook-key'] }}",
              "operation": "equal",
              "value2": "={{ $env.WEBHOOK_SECRET }}"
            }
          ]
        }
      },
      "id": "node_auth_check",
      "name": "Auth Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"Unauthorized\" }",
        "options": { "responseCode": 401 }
      },
      "id": "node_unauthorized",
      "name": "Return 401",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 460]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.body.from }}", "operation": "isNotEmpty" },
            { "value1": "={{ $json.body.clinicId }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_validate_inbound",
      "name": "Validate Inbound",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": false, \"error\": \"missing from or clinicId\" }",
        "options": { "responseCode": 400 }
      },
      "id": "node_bad_inbound",
      "name": "Return 400",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 460]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"received\": true }",
        "options": { "responseCode": 200 }
      },
      "id": "node_respond_immediately",
      "name": "Respond 200 Immediately",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "executionId",
              "value": "={{ $json.body.missedCallId || $execution.id }}"
            },
            { "name": "entityId", "value": "={{ $json.body.missedCallId || '' }}" },
            { "name": "entityType", "value": "inbound_sms" },
            { "name": "from", "value": "={{ $json.body.from }}" },
            { "name": "clinicId", "value": "={{ $json.body.clinicId }}" },
            { "name": "missedCallId", "value": "={{ $json.body.missedCallId || '' }}" },
            { "name": "messageBody", "value": "={{ $json.body.body }}" }
          ]
        }
      },
      "id": "node_set_execution_id",
      "name": "Set Execution ID",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "resource": "chat",
        "operation": "complete",
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a medical clinic assistant. Classify the patient's SMS reply. Reply with ONLY one word: BOOKING (patient wants to book), CANCEL (patient wants to cancel), INFO (patient asking for info), or OTHER."
            },
            {
              "role": "user",
              "content": "={{ $json.messageBody }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node_classify_intent",
      "name": "Classify Patient Intent",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [1340, 300],
      "continueOnFail": true,
      "credentials": {
        "openAiApi": {
          "id": "openai_creds",
          "name": "OpenAI Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.message?.content?.trim().toUpperCase() }}",
              "operation": "equal",
              "value2": "BOOKING"
            }
          ]
        }
      },
      "id": "node_is_booking",
      "name": "Is Booking Intent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/mark-recovered",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "clinicId", "value": "={{ $node[\"Set Execution ID\"].json.clinicId }}" },
            { "name": "missedCallId", "value": "={{ $node[\"Set Execution ID\"].json.missedCallId }}" },
            { "name": "executionId", "value": "={{ $node[\"Set Execution ID\"].json.executionId }}" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "id": "node_mark_recovered",
      "name": "Mark Recovered",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1780, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "send",
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $node[\"Set Execution ID\"].json.from }}",
        "message": "=Ευχαριστούμε! Θα επικοινωνήσουμε μαζί σας σύντομα για να κλείσουμε το ραντεβού σας.",
        "options": {
          "statusCallback": "={{ $env.BACKEND_API_URL + '/webhook/provider/twilio/status?clinicId=' + encodeURIComponent($node[\"Set Execution ID\"].json.clinicId) + '&missedCallId=' + encodeURIComponent($node[\"Set Execution ID\"].json.missedCallId) }}"
        }
      },
      "id": "node_reply_booking",
      "name": "Reply — Booking Confirmed",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [2000, 200],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 10000,
      "continueOnFail": true,
      "credentials": {
        "twilioApi": {
          "id": "twilio_creds",
          "name": "Twilio Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.sid }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_booking_sms_ok",
      "name": "Booking SMS Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [2220, 200]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "log",
              "value": "=Booking reply sent to {{ $node[\"Set Execution ID\"].json.from }} | executionId: {{ $node[\"Set Execution ID\"].json.executionId }} | twilioSid: {{ $json.sid || '' }}"
            },
            { "name": "smsStatus", "value": "sent" },
            { "name": "twilioSid", "value": "={{ $json.sid || '' }}" }
          ]
        }
      },
      "id": "node_log_booking_sent",
      "name": "Log Booking Reply Sent",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2440, 120]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/send-notification",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "type", "value": "sms_failure" },
            {
              "name": "executionId",
              "value": "={{ $node[\"Set Execution ID\"].json.executionId }}"
            },
            { "name": "error", "value": "={{ $json.errorMessage || $json.error?.message || 'Unknown SMS failure' }}" },
            { "name": "entityType", "value": "inbound_sms" },
            { "name": "entityId", "value": "={{ $node[\"Set Execution ID\"].json.entityId }}" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "id": "node_log_booking_failure",
      "name": "Log Booking Reply Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2440, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    },
    {
      "parameters": {
        "operation": "send",
        "from": "={{ $env.TWILIO_PHONE_NUMBER }}",
        "to": "={{ $node[\"Set Execution ID\"].json.from }}",
        "message": "=Ευχαριστούμε για την απάντησή σας. Θα επικοινωνήσουμε μαζί σας σύντομα.",
        "options": {
          "statusCallback": "={{ $env.BACKEND_API_URL + '/webhook/provider/twilio/status?clinicId=' + encodeURIComponent($node[\"Set Execution ID\"].json.clinicId) + '&missedCallId=' + encodeURIComponent($node[\"Set Execution ID\"].json.missedCallId) }}"
        }
      },
      "id": "node_reply_other",
      "name": "Reply — General Acknowledgement",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1780, 420],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 10000,
      "continueOnFail": true,
      "credentials": {
        "twilioApi": {
          "id": "twilio_creds",
          "name": "Twilio Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{ $json.sid }}", "operation": "isNotEmpty" }
          ]
        }
      },
      "id": "node_other_sms_ok",
      "name": "General SMS Sent?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [2000, 420]
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "log",
              "value": "=General reply sent to {{ $node[\"Set Execution ID\"].json.from }} | executionId: {{ $node[\"Set Execution ID\"].json.executionId }} | twilioSid: {{ $json.sid || '' }}"
            },
            { "name": "smsStatus", "value": "sent" },
            { "name": "twilioSid", "value": "={{ $json.sid || '' }}" }
          ]
        }
      },
      "id": "node_log_other_sent",
      "name": "Log General Reply Sent",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2220, 360]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_API_URL }}/automation/send-notification",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "type", "value": "sms_failure" },
            {
              "name": "executionId",
              "value": "={{ $node[\"Set Execution ID\"].json.executionId }}"
            },
            { "name": "error", "value": "={{ $json.errorMessage || $json.error?.message || 'Unknown SMS failure' }}" },
            { "name": "entityType", "value": "inbound_sms" },
            { "name": "entityId", "value": "={{ $node[\"Set Execution ID\"].json.entityId }}" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "id": "node_log_other_failure",
      "name": "Log General Reply Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [2220, 520],
      "credentials": {
        "httpHeaderAuth": {
          "id": "backend_api_key",
          "name": "Backend API Key"
        }
      }
    }
  ],
  "connections": {
    "Receive Inbound SMS": {
      "main": [[{ "node": "Auth Check", "type": "main", "index": 0 }]]
    },
    "Auth Check": {
      "main": [
        [{ "node": "Validate Inbound", "type": "main", "index": 0 }],
        [{ "node": "Return 401", "type": "main", "index": 0 }]
      ]
    },
    "Validate Inbound": {
      "main": [
        [{ "node": "Respond 200 Immediately", "type": "main", "index": 0 }],
        [{ "node": "Return 400", "type": "main", "index": 0 }]
      ]
    },
    "Respond 200 Immediately": {
      "main": [[{ "node": "Set Execution ID", "type": "main", "index": 0 }]]
    },
    "Set Execution ID": {
      "main": [[{ "node": "Classify Patient Intent", "type": "main", "index": 0 }]]
    },
    "Classify Patient Intent": {
      "main": [[{ "node": "Is Booking Intent?", "type": "main", "index": 0 }]]
    },
    "Is Booking Intent?": {
      "main": [
        [{ "node": "Mark Recovered", "type": "main", "index": 0 }],
        [{ "node": "Reply — General Acknowledgement", "type": "main", "index": 0 }]
      ]
    },
    "Mark Recovered": {
      "main": [[{ "node": "Reply — Booking Confirmed", "type": "main", "index": 0 }]]
    },
    "Reply — Booking Confirmed": {
      "main": [[{ "node": "Booking SMS Sent?", "type": "main", "index": 0 }]]
    },
    "Booking SMS Sent?": {
      "main": [
        [{ "node": "Log Booking Reply Sent", "type": "main", "index": 0 }],
        [{ "node": "Log Booking Reply Failure", "type": "main", "index": 0 }]
      ]
    },
    "Reply — General Acknowledgement": {
      "main": [[{ "node": "General SMS Sent?", "type": "main", "index": 0 }]]
    },
    "General SMS Sent?": {
      "main": [
        [{ "node": "Log General Reply Sent", "type": "main", "index": 0 }],
        [{ "node": "Log General Reply Failure", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
