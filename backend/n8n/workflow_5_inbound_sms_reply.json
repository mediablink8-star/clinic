{
  "name": "Workflow 5 — Inbound SMS Reply",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "inbound-sms",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "node_webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "inbound-sms"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "twilio-sid",
              "name": "TWILIO_ACCOUNT_SID",
              "value": "YOUR_TWILIO_ACCOUNT_SID",
              "type": "string"
            },
            {
              "id": "twilio-token",
              "name": "TWILIO_AUTH_TOKEN",
              "value": "YOUR_TWILIO_AUTH_TOKEN",
              "type": "string"
            },
            {
              "id": "twilio-sender",
              "name": "TWILIO_SENDER",
              "value": "YOUR_TWILIO_SENDER",
              "type": "string"
            },
            {
              "id": "backend-url",
              "name": "BACKEND_API_URL",
              "value": "YOUR_BACKEND_API_URL",
              "type": "string"
            },
            {
              "id": "api-key",
              "name": "AUTOMATION_API_KEY",
              "value": "YOUR_AUTOMATION_API_KEY",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node_set_creds",
      "name": "Set Credentials",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Credentials').first().json.BACKEND_API_URL }}/automation/process-inbound-sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $('Set Credentials').first().json.AUTOMATION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"{{ $json.From }}\",\n  \"body\": \"{{ $json.Body }}\",\n  \"clinicId\": \"{{ $json.clinicId }}\"\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_process_inbound",
      "name": "Process Inbound SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "has-reply",
              "leftValue": "={{ $json.reply }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node_has_reply",
      "name": "Has Reply?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.twilio.com/2010-04-01/Accounts/{{ $('Set Credentials').first().json.TWILIO_ACCOUNT_SID }}/Messages.json",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Basic {{ $base64($('Set Credentials').first().json.TWILIO_ACCOUNT_SID + ':' + $('Set Credentials').first().json.TWILIO_AUTH_TOKEN) }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "form",
        "formBodyParameters": {
          "parameters": [
            {
              "name": "From",
              "value": "={{ $('Set Credentials').first().json.TWILIO_SENDER }}"
            },
            {
              "name": "To",
              "value": "={{ $('Process Inbound SMS').first().json.from }}"
            },
            {
              "name": "Body",
              "value": "={{ $('Process Inbound SMS').first().json.reply }}"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_send_reply",
      "name": "Send Reply SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 200],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Credentials').first().json.BACKEND_API_URL }}/automation/log-sms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $('Set Credentials').first().json.AUTOMATION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"from\": \"{{ $('Process Inbound SMS').first().json.from }}\",\n  \"sid\": \"{{ $json.sid }}\",\n  \"status\": \"{{ $json.status }}\",\n  \"type\": \"inbound_reply\"\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_log_sms",
      "name": "Log Reply SMS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Credentials').first().json.BACKEND_API_URL }}/automation/log-error",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $('Set Credentials').first().json.AUTOMATION_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"inbound_sms_failed\",\n  \"from\": \"{{ $('Process Inbound SMS').first().json.from }}\",\n  \"error\": \"{{ $('Process Inbound SMS').last().json.error || $json.message }}\"\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "node_log_error",
      "name": "Log Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 420]
    }
  ],
  "connections": {
    "Webhook Trigger": {
      "main": [
        [
          {
            "node": "Set Credentials",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Set Credentials": {
      "main": [
        [
          {
            "node": "Process Inbound SMS",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Process Inbound SMS": {
      "main": [
        [
          {
            "node": "Has Reply?",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has Reply?": {
      "main": [
        [
          {
            "node": "Send Reply SMS",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Send Reply SMS": {
      "main": [
        [
          {
            "node": "Log Reply SMS",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
