{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "worker": "node worker.js",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:api": "nodemon index.js",
    "dev:worker": "nodemon worker.js",
    "start:prod": "cross-env NODE_ENV=production node index.js",
    "dev:win": "cross-env NODE_ENV=development nodemon index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:deploy": "prisma migrate deploy",
    "postinstall": "node -e \"if(process.env.DATABASE_URL){require('child_process').execFileSync('npx',['prisma','generate'],{stdio:'inherit'})}else{console.warn('Skipping prisma generate: DATABASE_URL is not set')}\"",
    "backfill:recovery-cases": "node scripts/backfillRecoveryCases.js",
    "seed:holidays": "node prisma/seed-holidays.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=1 --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=integration --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=unit --runInBand --forceExit",
    "deploy": "npm run migrate:deploy && npm start",
    "health": "node -e \"fetch('http://localhost:4000/api/health').then(r=>r.json()).then(console.log)\""
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "testRegex": ".*\\.(test|spec)\\.js$",
    "setupFilesAfterSetup": [
      "<rootDir>/tests/setup.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "!**/*.test.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.39.0",
    "@sentry/profiling-node": "^10.39.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.69.3",
    "chrono-node": "^2.7.9",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.3.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "stripe": "^17.7.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "qs": "6.15.2"
  }
}