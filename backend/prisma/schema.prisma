// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Clinic {
  id           String        @id @default(cuid())
  name         String
  location     String
  phone        String
  email        String
  isActive     Boolean       @default(true) // Master switch for clinic workflows
  workingHours String // Stored as JSON string
  services     String // Stored as JSON string
  policies     String // Stored as JSON string
  webhookUrl   String? // Global URL for n8n/Make integration
  webhookSecret String       @default(cuid()) // Secret for HMAC signature
  webhookMissedCall String? // Event-specific override
  webhookAppointment String? // Event-specific override
  webhookReminders String? // Event-specific override
  webhookDirectSms String? // Event-specific override
  webhookInboundSms String? // Event-specific override
  googleId      String?      @unique
  avatarUrl     String?      @default("https://images.unsplash.com/photo-1516542077369-bc831dfb1b17?q=80&w=1000")
  messageCredits    Int           @default(100)
  monthlyCreditLimit Int           @default(100)
  creditResetDate    DateTime      @default(now())
  dailyMessageCap    Int           @default(300)
  dailyUsedCount     Int           @default(0)
  lastResetDay       DateTime      @default(now())
  apiKeys            String       @default("{}") // Stores encrypted JSON of API keys
  aiConfig           String       @default("{}") // Stores JSON of AI configuration (tone, services, value, etc)
  timezone           String       @default("Europe/Athens")
  
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  notifications Notification[]
  messageLogs   MessageLog[]
  auditLogs     AuditLog[]
  missedCalls   MissedCall[]
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(RECEPTIONIST)
  name         String   @default("")
  clinicId     String
  clinic       Clinic   @relation(fields: [clinicId], references: [id])
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  OWNER
  RECEPTIONIST
  ASSISTANT
}

model Patient {
  id           String        @id @default(cuid())
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  name         String
  phone        String
  email        String?
  appointments Appointment[]
  missedCalls  MissedCall[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([clinicId, phone]) // Unique per clinic
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum Priority {
  URGENT
  NORMAL
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  clinic          Clinic            @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  startTime       DateTime
  endTime         DateTime
  reason          String?           // Greek description
  status          AppointmentStatus @default(PENDING)
  priority        Priority          @default(NORMAL)
  notes           String?
  aiClassification String?           // Summary generated by AI
  feedbacks       Feedback[]
  notifications   Notification[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Feedback {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  sentiment     String?     // POSITIVE, NEUTRAL, NEGATIVE
  createdAt     DateTime    @default(now())
}

model MessageLog {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  type      String   // SMS, WHATSAPP, VOICE
  cost      Int      @default(1)
  status    String   // SENT, FAILED, BLOCKED, PENDING
  error     String?
  timestamp DateTime @default(now())

  @@index([clinicId])
}

enum NotificationType {
  REMINDER
  FOLLOW_UP
  NO_SHOW_ALERT
  MARKETING
}

model Notification {
  id            String           @id @default(cuid())
  clinicId      String
  clinic        Clinic           @relation(fields: [clinicId], references: [id])
  appointmentId String?
  appointment   Appointment?      @relation(fields: [appointmentId], references: [id])
  type          NotificationType
  sentAt        DateTime?
  scheduledFor  DateTime
  status        String           @default("SCHEDULED")
  message       String
  createdAt     DateTime         @default(now())

  @@index([clinicId])
  @@index([status])
  @@index([scheduledFor])
}

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  userId    String?
  action    String   // e.g., CREATE_APPOINTMENT, DELETE_PATIENT
  entity    String   // e.g., APPOINTMENT, PATIENT
  entityId  String?
  details   String?  // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([createdAt])
}

model MissedCall {
  id               String           @id @default(cuid())
  clinicId         String
  clinic           Clinic           @relation(fields: [clinicId], references: [id])
  fromNumber       String
  callSid          String?          @unique // Twilio/external call ID for dedup (Fix 4)
  patientId        String?
  patient          Patient?         @relation(fields: [patientId], references: [id])
  status           MissedCallStatus @default(DETECTED)
  smsStatus        String           @default("pending") // pending | processing | sent | failed | scheduled (Fix 5)
  smsError         String?          // last SMS error message
  scheduledSmsAt   DateTime?        // When outside working hours, SMS is scheduled for this time
  estimatedRevenue Float            @default(150.0)
  aiConversation   String?          // Stored JSON of SMS history
  lastSmsSentAt    DateTime?
  recoveredAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([clinicId])
  @@index([status])
  @@index([smsStatus])
  @@index([createdAt])
  @@index([recoveredAt])
}

enum MissedCallStatus {
  DETECTED
  RECOVERING
  RECOVERED
  LOST
}
