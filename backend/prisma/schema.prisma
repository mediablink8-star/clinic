// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id           String        @id @default(cuid())
  name         String
  location     String
  phone        String
  email        String
  password     String        @default("hashed_password_placeholder") // Will be hashed
  workingHours String // Stored as JSON string
  services     String // Stored as JSON string
  policies     String // Stored as JSON string
  webhookUrl   String? // URL for n8n/Make integration
  webhookSecret String       @default(cuid()) // Secret for HMAC signature
  googleId      String?      @unique
  avatarUrl     String?      @default("https://images.unsplash.com/photo-1516542077369-bc831dfb1b17?q=80&w=1000")
  patients     Patient[]
  appointments Appointment[]
  notifications Notification[]
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Patient {
  id           String        @id @default(cuid())
  clinicId     String
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  name         String
  phone        String
  email        String?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([clinicId, phone]) // Unique per clinic
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum Priority {
  URGENT
  NORMAL
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  clinic          Clinic            @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  startTime       DateTime
  endTime         DateTime
  reason          String?           // Greek description
  status          AppointmentStatus @default(PENDING)
  priority        Priority          @default(NORMAL)
  notes           String?
  aiClassification String?           // Summary generated by AI
  feedbacks       Feedback[]
  notifications   Notification[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Feedback {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  sentiment     String?     // POSITIVE, NEUTRAL, NEGATIVE
  createdAt     DateTime    @default(now())
}

enum NotificationType {
  REMINDER
  FOLLOW_UP
  NO_SHOW_ALERT
  MARKETING
}

model Notification {
  id            String           @id @default(cuid())
  clinicId      String
  clinic        Clinic           @relation(fields: [clinicId], references: [id])
  appointmentId String?
  appointment   Appointment?      @relation(fields: [appointmentId], references: [id])
  type          NotificationType
  sentAt        DateTime?
  scheduledFor  DateTime
  status        String           @default("SCHEDULED")
  message       String
  createdAt     DateTime         @default(now())
}
